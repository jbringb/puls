# Normalize line endings: store text as LF in the repo, check out LF everywhere.
* text=auto eol=lf

# Explicit text types
*.go     text eol=lf
*.mod    text eol=lf
*.sum    text eol=lf
*.sql    text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
Dockerfile text eol=lf

# Binary
*.exe binary
